<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizApp.CategoryPage">
    <Grid Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" CornerRadius="22" WidthRequest="44" HeightRequest="44" Padding="8" HorizontalOptions="End" VerticalOptions="Start">
            <!-- Иконка назад -->
            <Path Data="M14 18 L8 12 L14 6"
           Stroke="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
           StrokeThickness="2"
           StrokeLineCap="Round"
           StrokeLineJoin="Round"
           WidthRequest="20" HeightRequest="20"
           HorizontalOptions="Center" VerticalOptions="Center"  />
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" NumberOfTapsRequired="1" />
            </Frame.GestureRecognizers>
        </Frame>
        <VerticalStackLayout Spacing="18" Padding="20" VerticalOptions="Center" Grid.Row="1">

            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <Label Text="Выберите категорию" FontSize="24" HorizontalOptions="Center" Grid.Column="0" />
            </Grid>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Кино -->
                <Frame CornerRadius="12" HasShadow="True" BackgroundColor="{StaticResource Gray100}" Padding="12">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🎥" FontSize="28" HorizontalOptions="Center" TextColor="#666" />
                        <Label Text="Кино" FontSize="16" HorizontalOptions="Center" TextColor="#333" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer CommandParameter="Kino" Tapped="OnTopCategoryTapped" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Природа -->
                <Frame CornerRadius="12" HasShadow="True" BackgroundColor="{StaticResource Gray100}" Padding="12" Grid.Column="1">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🌿" FontSize="28" HorizontalOptions="Center" TextColor="#666" />
                        <Label Text="Природа" FontSize="16" HorizontalOptions="Center" TextColor="#333" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer CommandParameter="Priroda" Tapped="OnTopCategoryTapped" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- География -->
                <Frame CornerRadius="12" HasShadow="True" BackgroundColor="{StaticResource Gray100}" Padding="12" Grid.Row="1">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🗺️" FontSize="28" HorizontalOptions="Center" TextColor="#666" />
                        <Label Text="География" FontSize="16" HorizontalOptions="Center" TextColor="#333" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer CommandParameter="Geografiya" Tapped="OnTopCategoryTapped" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- История  -->
                <Frame CornerRadius="12" HasShadow="True" BackgroundColor="{StaticResource Gray100}" Padding="12" Grid.Row="1" Grid.Column="1">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🏺" FontSize="28" HorizontalOptions="Center" TextColor="#666" />
                        <Label Text="История" FontSize="16" HorizontalOptions="Center" TextColor="#333" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer CommandParameter="Istoriya" Tapped="OnTopCategoryTapped" />
                    </Frame.GestureRecognizers>
                </Frame>
            </Grid>

        </VerticalStackLayout>
    </Grid>
    

</ContentPage>
